# --- TallyPrime connection ---
# Host where TallyPrime's XML/HTTP gateway is reachable.
# Use "localhost" when the MCP server runs on the same machine as Tally,
# or the LAN IP of the Tally machine otherwise.
TALLY_HOST=localhost

# Port of Tally's XML/HTTP gateway (default 9000).
TALLY_PORT=9000

# Default company name to operate on. Must match the Tally company name EXACTLY.
# Leave blank to use whichever company Tally has currently active.
TALLY_COMPANY=

# Request timeout in seconds for calls to Tally.
TALLY_TIMEOUT=30

# --- Safety ---
# Master switch for write operations (creating vouchers / ledgers).
# Phase 1 is read-only; keep this "false" until you have read docs/SETUP.md
# and backed up your company data.
TALLY_ALLOW_WRITES=false
